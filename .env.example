# E-Voting App - Environment Configuration Template
# Copy this to .env and fill with your actual values

# ═══════════════════════════════════════════════════════════════
# SMTP EMAIL CONFIGURATION (for sending emails)
# ═══════════════════════════════════════════════════════════════

# Gmail SMTP Configuration (Recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=gisbertkapinga003@gmail.com
SMTP_PASSWORD=bcsasatfhwekzosa
SMTP_FROM=gisbertkapinga003@gmail.com
USE_SSL=false

# NOTES:
# 1. For Gmail, you MUST use an "App Password", not your regular password
# 2. To create App Password:
#    - Go to: https://myaccount.google.com/security
#    - Enable 2-Step Verification
#    - Create App Password: Security > App passwords > Mail > Generate
# 3. Port 587 uses TLS (set USE_SSL=false)
# 4. Port 465 uses SSL (set USE_SSL=true)

# ═══════════════════════════════════════════════════════════════
# OTHER EMAIL PROVIDERS
# ═══════════════════════════════════════════════════════════════

# Outlook/Hotmail SMTP:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=your-email@outlook.com
# SMTP_PASSWORD=your-password
# USE_SSL=false

# Yahoo SMTP:
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=587
# SMTP_USER=your-email@yahoo.com
# SMTP_PASSWORD=your-app-password
# USE_SSL=false

# Custom SMTP Server:
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASSWORD=your-password
# USE_SSL=false

# ═══════════════════════════════════════════════════════════════
# APP CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# Default Admin Credentials (change after first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ═══════════════════════════════════════════════════════════════
# SECURITY NOTES
# ═══════════════════════════════════════════════════════════════

# ⚠️ IMPORTANT:
# - Never commit .env file to version control (Git)
# - Add .env to your .gitignore file
# - Keep App Passwords secure and private
# - Rotate passwords regularly
# - Use environment-specific configurations for dev/staging/production
